<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.qa.lib.ssh.gui.controller.SshController"
            style="-fx-padding:10 10 0 10;">
    <center>
        <fx:include source="/view/ssh-target-jump-view.fxml" fx:id="targetJump"/>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10 0 0 0">
            <Button fx:id="btnSave" text="%ssh.gui.save" prefWidth="100" prefHeight="30"/>
            <Button fx:id="btnClose" text="%ssh.gui.close" prefWidth="100" prefHeight="30"/>
        </HBox>
    </bottom>
</BorderPane>
