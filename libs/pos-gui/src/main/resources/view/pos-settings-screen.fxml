<?import javafx.scene.layout.HBox?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/8"
            fx:controller="com.qa.lib.pos.gui.controller.SettingsController">
    <center >
        <SplitPane dividerPositions="0.3" >
            <fx:include fx:id="leftFileList" source="/view/settings-file-list-view.fxml"/>
            <fx:include fx:id="settingsForm" source="/view/settings-form-view.fxml"/>
        </SplitPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" maxWidth="Infinity" style="-fx-padding: 10 10 0 10">
            <Button fx:id="btnSave" text="%pos.gui.save" prefWidth="100" prefHeight="30"/>
            <Button fx:id="btnClose" text="%pos.gui.close" prefWidth="100" prefHeight="30"/>
        </HBox>
    </bottom>
</BorderPane>

