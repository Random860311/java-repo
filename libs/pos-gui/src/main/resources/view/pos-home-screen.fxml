<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<BorderPane
        xmlns:fx="http://javafx.com/fxml/1"
        xmlns="http://javafx.com/javafx/8"
        fx:controller="com.qa.lib.pos.gui.controller.PosHomeController">

    <center>
        <FlowPane hgap="15"
                  vgap="15"
                  prefWrapLength="500"
                  style="-fx-padding: 20;">

            <Button fx:id="btnSettings" text="%pos.gui.settings" prefWidth="120" prefHeight="60"/>

            <Button text="Button 3" prefWidth="120" prefHeight="60"/>
            <Button text="Button 4" prefWidth="120" prefHeight="60"/>
            <Button text="Button 5" prefWidth="120" prefHeight="60"/>

        </FlowPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" maxWidth="Infinity" style="-fx-padding: 10 10 0 10">
            <Button fx:id="btnClose" text="%pos.gui.close" prefWidth="100" prefHeight="30"/>
        </HBox>
    </bottom>
</BorderPane>


